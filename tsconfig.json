{
    "extends": "@tsconfig/svelte/tsconfig.json",
    "compilerOptions": {
        "esModuleInterop": true,
        "isolatedModules": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "plugins": [
            {"name": "typescript-plugin-css-modules"},
        ],
        "resolveJsonModule": true,
        "rootDir": "src",
        "strict": true,
        "target": "esnext",
        "types": ["jquery", "svelte"],
        "verbatimModuleSyntax": true
    },
    "include": [
        "src/upstream/asyncglk/src/global.d.ts",
        "src/types.d.ts",
        "src/common/**/*",
        "src/inform7/*",
        "src/iplayif.com/app/src/*",
        "src/tools/*"
    ],
    "exclude": [
        "node_modules"
    ]
}